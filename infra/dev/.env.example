# Copy this file to .env and fill in your values before running ./up.sh.
# `up.sh` substitutes `__VAR__` placeholders in keycloak/portal-realm-dev.json
# into a gitignored tmp file and then `docker compose up`, mirroring the
# E2ETestcontainersDriver.kt:159 string-replace pattern — never commit a
# realm with plaintext secrets.

# Docker registry hosting the CRS image (required).
CRS_DOCKER_REGISTRY=your.docker.registry.example.com

# CRS image version to use (optional, defaults to the version pinned in docker-compose.yml).
# CRS_VERSION=2.0.84-3229

# Keycloak realm secrets — substituted into portal-realm-dev.json at startup.
# These are local-dev only; production / CI uses different values supplied by
# the launcher (E2ETestcontainersDriver). Default values below match the
# pre-envsubst defaults the dev stack used to ship with — change at will.
PORTAL_BFF_SECRET=dev-bff-secret
PORTAL_E2E_DIRECT_SECRET=dev-direct-secret
E2E_ADMIN_PASSWORD=admin
E2E_VIEWER_PASSWORD=viewer
