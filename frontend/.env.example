# Base URL for Jira quick-links in ComponentDetailPage header.
# When set, a Jira icon appears linking to {VITE_JIRA_BASE_URL}/browse/{projectKey}.
# Leave unset to hide the Jira quick-link.
VITE_JIRA_BASE_URL=https://jira.example.com

# Base URL for Git quick-links in ComponentDetailPage header.
# When set, a Git icon appears linking to {VITE_GIT_BASE_URL}/{vcsPath}.
# Leave unset to hide the Git quick-link.
VITE_GIT_BASE_URL=https://git.example.com

# Base URL for TeamCity quick-links in the /components list view.
# When set, a hammer icon appears linking to {VITE_TC_BASE_URL}/{component.name}.
# Leave unset to hide the TC quick-link.
VITE_TC_BASE_URL=https://tc.example.com

# Base URL for Document Management System (DMS) quick-links in /components.
# When set, a database icon appears linking to {VITE_DMS_BASE_URL}/{component.name}.
# Leave unset to hide the DMS quick-link.
VITE_DMS_BASE_URL=https://dms.example.com
