# Base URL for Jira quick-links in ComponentDetailPage header.
# When set, a Jira icon appears linking to {VITE_JIRA_BASE_URL}/browse/{projectKey}.
# Leave unset to hide the Jira quick-link.
VITE_JIRA_BASE_URL=https://jira.example.com

# Base URL for Git quick-links in ComponentDetailPage header.
# When set, a Git icon appears linking to {VITE_GIT_BASE_URL}/{vcsPath}.
# Leave unset to hide the Git quick-link.
VITE_GIT_BASE_URL=https://git.example.com
